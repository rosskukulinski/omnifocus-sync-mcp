# Omni Sync Server account (the same credentials you use in OmniFocus > Sync).
OMNIFOCUS_SYNC_USERNAME=your-omni-account-name
OMNIFOCUS_SYNC_PASSWORD=your-omni-account-password

# Encryption passphrase for the database. OmniFocus derives this from the sync
# password by default, so leave it unset unless you set a separate passphrase.
# OMNIFOCUS_ENCRYPTION_PASSPHRASE=

# Optional overrides.
# OMNIFOCUS_SYNC_URL=https://sync.omnigroup.com
# OMNIFOCUS_DATABASE=OmniFocus.ofocus
# OMNIFOCUS_CLIENT_NAME=omnifocus-sync-mcp@my-nas
# OMNIFOCUS_CLIENT_STATE_FILE=~/.config/omnifocus-sync-mcp/client.json

# Set to 1/true to refuse all writes (safe read-only mode).
# OMNIFOCUS_READ_ONLY=1
